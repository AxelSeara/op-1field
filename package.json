{
  "name": "op1-field-learning-app",
  "version": "1.1.0",
  "description": "Offline-first OP-1 Field learning app",
  "main": "main.js",
  "author": "StreetShark123",
  "license": "MIT",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "qa:locales": "node scripts/check-locales.mjs",
    "qa:structure": "node scripts/check-course-structure.mjs",
    "qa:content": "node scripts/check-content-quality.mjs",
    "test:e2e": "playwright test",
    "qa": "npm run qa:locales && npm run qa:structure && npm run qa:content",
    "qa:full": "npm run qa && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "globals": "^17.5.0"
  },
  "build": {
    "appId": "com.streetshark.op1field",
    "productName": "OP-1 Field Learning App",
    "icon": "assets/app-icon/op1-app-icon.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "op1-curso-final.html",
      "assets/**/*",
      "docs/**/*",
      "README.md",
      "main.js",
      "package.json"
    ],
    "win": {
      "icon": "assets/app-icon/op1-app-icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
